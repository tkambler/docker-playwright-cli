#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="tkambler/playwright-cli:latest"

# Find install directory: prefer ~/bin if it exists and is in PATH,
# fall back to ~/.local/bin
INSTALL_DIR=""
for dir in "${HOME}/bin" "${HOME}/.local/bin"; do
    if [[ -d "$dir" && ":$PATH:" == *":${dir}:"* ]]; then
        INSTALL_DIR="$dir"
        break
    fi
done

if [[ -z "$INSTALL_DIR" ]]; then
    echo "Error: Neither ~/bin nor ~/.local/bin exists and is in your PATH."
    echo "Create one of them and add it to your PATH, then re-run this script."
    exit 1
fi

SCRIPT_PATH="${INSTALL_DIR}/playwright-cli"

# Ensure the image exists
if ! docker image inspect "$IMAGE_NAME" >/dev/null 2>&1; then
    echo "Image '$IMAGE_NAME' not found. Building it now..."
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    docker pull "$IMAGE_NAME"
    # docker build -t "$IMAGE_NAME" "$SCRIPT_DIR"
fi

# Write the wrapper script
cat > "$SCRIPT_PATH" << 'WRAPPER'
#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="tkambler/playwright-cli:latest"
CONTAINER_NAME="playwright-cli-session"
CONFIG="--config /etc/playwright-cli.config.json"

is_running() {
    docker ps --filter "name=^${CONTAINER_NAME}$" --format '{{.Names}}' 2>/dev/null | grep -q .
}

# --ipc=host \
# --shm-size=256m \

ensure_container() {
    if is_running; then
        return
    fi
    # Remove stale stopped container if it exists
    docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
    # Start a long-lived container in the background
    mkdir -p "$HOME/playwright-cli"
    docker run -d \
        --init \
        --shm-size=2g \
        --name "$CONTAINER_NAME" \
        -v "$HOME/playwright-cli:/work" \
        -w /work \
        --entrypoint tail \
        "$IMAGE_NAME" \
        -f /dev/null >/dev/null
}

# Handle special commands
case "${1:-}" in
    close-all|kill-all)
        if is_running; then
            docker exec "$CONTAINER_NAME" playwright-cli $CONFIG "$@"
            docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
        fi
        exit 0
        ;;
esac

ensure_container
exec docker exec "$CONTAINER_NAME" playwright-cli $CONFIG "$@"
WRAPPER

chmod +x "$SCRIPT_PATH"

echo "Installed playwright-cli to $SCRIPT_PATH"
